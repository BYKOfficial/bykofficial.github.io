// VISIBLE BREADCRUMBS — Dynamic Update
// ============================================
const breadcrumbMap = {
'home': 'Welcome to BYK',
'about': 'About BYK',
'channels': 'YouTube Channels',
'social': 'Social Media',
'telegram': 'Telegram Community',
'proof': 'BYK In Numbers',
'achievements': 'BYK Journey',
'videos': 'Featured Videos',
'fanwall': 'Fan Wall',
'mediakit': 'Work With BYK',
'faq': 'FAQ',
'newsletter': 'Newsletter',
'contact': 'Contact Us'
};
const bcObs = new IntersectionObserver(entries => {
entries.forEach(entry => {
if(entry.isIntersecting){
const id = entry.target.id;
const label = breadcrumbMap[id];
if(label){
const bc = document.getElementById('breadcrumb-current');
if(bc) bc.textContent = label;
}
}
});
}, { threshold: 0.3 });
Object.keys(breadcrumbMap).forEach(id => {
const el = document.getElementById(id);
if(el) bcObs.observe(el);
});
