// Telegram tabs
function showTg(id, el){
document.querySelectorAll('.tg-panel').forEach(p=>p.classList.remove('active'));
document.querySelectorAll('.tg-tab').forEach(t=>t.classList.remove('active'));
document.getElementById('tg-'+id).classList.add('active');
